---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    id: 'market-intelligence',
    title: 'Market Intelligence',
    tagline: 'Continuous coverage of the markets that matter to you.',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20h.01M7 20v-4M12 20v-8M17 20V8M22 4l-5 5-4-4-6 6"/></svg>`,
    desc: `Our flagship market intelligence service provides institutional clients with continuous, forward-looking coverage across commodity markets, capital flows, and emerging market dynamics.

Each coverage area is assigned a dedicated senior analyst supported by a regional research network. Clients receive a weekly intelligence bulletin, a monthly in-depth report, and on-demand analyst briefings.`,
    deliverables: [
      'Weekly intelligence bulletins (3–5 pages)',
      'Monthly deep-dive research reports (30–60 pages)',
      'Quarterly market outlook documents',
      'Real-time data alerts via our client portal',
      'Unlimited analyst briefing calls',
    ],
    sectors: ['Base Metals & Mining', 'Precious Metals', 'Energy Transition Minerals', 'Agricultural Commodities', 'Freight & Logistics'],
  },
  {
    id: 'due-diligence',
    title: 'Due Diligence Support',
    tagline: 'Research built to withstand investment committee scrutiny.',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35M11 8v3M11 14h.01"/></svg>`,
    desc: `Crestmore provides structured due diligence research for investment teams evaluating transactions in commodity-linked sectors and emerging markets. Our work supports M&A processes, private equity investments, infrastructure financing, and project finance decisions.

We operate under NDA and work within your timeline. Our team has experience supporting transactions ranging from $50M to over $5Bn in enterprise value.`,
    deliverables: [
      'Market and competitive landscape assessment',
      'Commodity price and demand scenario modelling',
      'Regulatory and country risk assessment',
      'Supply chain and logistics analysis',
      'Management presentation support',
    ],
    sectors: ['Private Equity', 'Infrastructure Funds', 'Corporate M&A', 'Development Finance', 'Project Finance'],
  },
  {
    id: 'country-risk',
    title: 'Country Risk Assessment',
    tagline: '47 markets. Specialist coverage. No generic scorecards.',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    desc: `Generic country risk scores mask the nuance that drives real investment outcomes. Crestmore's country risk assessments are built from primary research, structured interviews with government officials and industry participants, and deep institutional knowledge of how each market actually operates.

We cover 47 countries across Sub-Saharan Africa, Latin America, MENA, Central Asia, and Southeast Asia — in meaningful depth, not superficially.`,
    deliverables: [
      'Sovereign risk profiles (political, fiscal, regulatory)',
      'Sector-specific regulatory risk assessments',
      'Expropriation and contract enforcement analysis',
      'Currency and capital controls assessment',
      'Quarterly risk rating updates with change rationale',
    ],
    sectors: ['Mining & Extractives', 'Infrastructure', 'Agriculture', 'Manufacturing', 'Financial Services'],
  },
  {
    id: 'sector-coverage',
    title: 'Sector Deep-Dives',
    tagline: 'Specialist analysis you cannot get from generalist providers.',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    desc: `Our sector deep-dives provide the kind of granular, technically-grounded analysis that generalist research houses cannot replicate. Each report is anchored in primary data collection, often including field visits, operator interviews, and trade data analysis.

Published on a scheduled basis, our sector reports function as definitive reference documents for institutional investors and corporate strategists.`,
    deliverables: [
      'Annual sector outlook reports (80–120 pages)',
      'Supply-demand modelling to 10-year horizon',
      'Price forecasting with scenario analysis',
      'Competitive landscape mapping',
      'Key risk and opportunity matrices',
    ],
    sectors: ['Copper & Critical Minerals', 'Gold & Silver', 'Iron Ore & Steel', 'Lithium & Battery Materials', 'Fertilisers & Agri-inputs'],
  },
  {
    id: 'advisory-retainers',
    title: 'Advisory Retainers',
    tagline: 'A Crestmore analyst on your team — without the overhead.',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`,
    desc: `Our retainer clients receive priority access to Crestmore analysts, our proprietary datasets, and the full body of published research. Retainers are structured as ongoing relationships, typically for 12-month periods, enabling us to provide contextualised analysis that deepens over time.

This is our most valued service tier. We work with a limited number of retainer clients to ensure quality is maintained.`,
    deliverables: [
      'Unlimited analyst Q&A sessions (phone, video, in-person)',
      'Full access to all published research and data',
      'Custom research requests (up to 4 per quarter)',
      'Priority turnaround on time-sensitive queries',
      'Annual in-person strategy review session',
    ],
    sectors: ['Sovereign Wealth Funds', 'Pension Funds', 'Commodity Trading Houses', 'Corporate Strategy Teams', 'Family Offices'],
  },
  {
    id: 'custom-research',
    title: 'Custom Research',
    tagline: 'Your specific question. Our dedicated research team.',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    desc: `For research needs that fall outside our standard service lines, we offer bespoke commissioned research. From a rapid 48-hour briefing note to a multi-month deep-dive programme, we tailor our approach to your timeline, budget, and deliverable requirements.

Custom research mandates are subject to availability and a brief scoping conversation with our senior team.`,
    deliverables: [
      'Rapid briefing notes (24–72 hour turnaround)',
      'Structured research reports to client specification',
      'Data builds and proprietary database construction',
      'Expert network interviews and synthesis',
      'Presentation decks for board or IC use',
    ],
    sectors: ['All sectors under active Crestmore coverage', 'Adjacent sectors on a case-by-case basis'],
  },
];
---

<BaseLayout
  title="Services — Crestmore Research"
  description="Six integrated market intelligence service lines for institutional investors, corporate strategists, and policy organisations. Independent research. No conflicts."
  pageType="default"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content">
        <p class="section__eyebrow section__eyebrow--gold">What We Offer</p>
        <h1 class="page-hero__title">Our Services</h1>
        <p class="page-hero__sub">Six integrated service lines — from continuous market intelligence to bespoke commissioned research — designed for the demands of institutional decision-making.</p>
      </div>
    </div>
  </section>

  <!-- Services detail -->
  <section class="section">
    <div class="container">
      <div class="services-detail">
        {services.map((svc, i) => (
          <div class="service-detail" id={svc.id}>
            <div class="service-detail__header">
              <div class="service-detail__icon" set:html={svc.icon} />
              <div>
                <h2 class="service-detail__title">{svc.title}</h2>
                <p class="service-detail__tagline">{svc.tagline}</p>
              </div>
            </div>
            <div class="service-detail__body">
              <div class="service-detail__desc">
                {svc.desc.split('\n\n').map(para => (
                  <p>{para}</p>
                ))}
              </div>
              <div class="service-detail__meta">
                <div class="service-detail__deliverables">
                  <h4>Key Deliverables</h4>
                  <ul>
                    {svc.deliverables.map(d => <li>{d}</li>)}
                  </ul>
                </div>
                <div class="service-detail__sectors">
                  <h4>Typical Clients / Sectors</h4>
                  <ul>
                    {svc.sectors.map(s => <li>{s}</li>)}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta-banner">
    <div class="container">
      <div class="cta-banner">
        <div class="cta-banner__text">
          <p class="section__eyebrow section__eyebrow--gold">Get Started</p>
          <h2 class="cta-banner__title">Request a Scoping Conversation</h2>
          <p class="cta-banner__sub">Tell us your research need and we will propose the right service structure within one business day.</p>
        </div>
        <div class="cta-banner__actions">
          <a href="/contact" class="btn btn--gold btn--lg">Contact Our Team</a>
          <a href="/methodology" class="btn btn--outline-light btn--lg">Our Methodology →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.services-detail {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.service-detail {
  padding: 56px 0;
  border-bottom: 1px solid var(--border);
}
.service-detail:last-child { border-bottom: none; }

.service-detail__header {
  display: flex;
  align-items: flex-start;
  gap: 24px;
  margin-bottom: 32px;
}

.service-detail__icon {
  color: var(--gold);
  flex-shrink: 0;
  margin-top: 4px;
}

.service-detail__title {
  font-family: 'Playfair Display', serif;
  font-size: 30px;
  font-weight: 700;
  color: var(--navy-dark);
  margin-bottom: 6px;
  line-height: 1.2;
}

.service-detail__tagline {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  color: var(--accent);
  font-weight: 500;
  margin: 0;
  font-style: italic;
}

.service-detail__body {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 48px;
}

.service-detail__desc p {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  color: var(--text-secondary);
  line-height: 1.8;
}

.service-detail__meta {
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.service-detail__deliverables h4,
.service-detail__sectors h4 {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.service-detail__deliverables ul,
.service-detail__sectors ul {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.service-detail__deliverables li,
.service-detail__sectors li {
  font-family: 'Inter', sans-serif;
  font-size: 13.5px;
  color: var(--text-secondary);
  padding-left: 16px;
  position: relative;
  line-height: 1.5;
}

.service-detail__deliverables li::before,
.service-detail__sectors li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--gold);
}

@media (max-width: 768px) {
  .service-detail__body { grid-template-columns: 1fr; gap: 32px; }
  .service-detail__header { flex-direction: column; gap: 16px; }
  .service-detail__title { font-size: 24px; }
}
</style>
