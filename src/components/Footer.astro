---
// Footer.astro — 5-column authority footer with regulatory disclaimer
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <!-- Top footer: 5 columns -->
  <div class="site-footer__top">
    <div class="container">
      <div class="site-footer__cols">

        <!-- Col 1: Brand -->
        <div class="site-footer__col site-footer__col--brand">
          <div class="site-footer__logo-wordmark">
            <span class="site-footer__logo-name">CRESTMORE</span>
            <span class="site-footer__logo-sub">RESEARCH</span>
          </div>
          <p class="site-footer__tagline">
            Independent strategic intelligence for institutional decision-makers navigating complex global markets.
          </p>
          <div class="site-footer__social">
            <a href="https://linkedin.com" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://twitter.com" aria-label="X (Twitter)" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://bloomberg.com" aria-label="Bloomberg Terminal" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M8 8h8M8 16h4"/></svg>
            </a>
          </div>
          <div class="site-footer__cert">
            <span class="site-footer__cert-badge">ISO 27001</span>
            <span class="site-footer__cert-badge">GDPR</span>
            <span class="site-footer__cert-badge">SOC 2</span>
          </div>
        </div>

        <!-- Col 2: Research -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Research</h4>
          <ul class="site-footer__links">
            <li><a href="/research">All Reports</a></li>
            <li><a href="/research?cat=commodities">Commodities</a></li>
            <li><a href="/research?cat=emerging-markets">Emerging Markets</a></li>
            <li><a href="/research?cat=capital-flows">Capital Flows</a></li>
            <li><a href="/research?cat=macro">Macro Outlook</a></li>
            <li><a href="/insights">Insights &amp; Commentary</a></li>
          </ul>
        </div>

        <!-- Col 3: Services -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Services</h4>
          <ul class="site-footer__links">
            <li><a href="/services#market-intelligence">Market Intelligence</a></li>
            <li><a href="/services#due-diligence">Due Diligence</a></li>
            <li><a href="/services#country-risk">Country Risk Assessment</a></li>
            <li><a href="/services#sector-coverage">Sector Coverage</a></li>
            <li><a href="/services#custom-research">Custom Research</a></li>
            <li><a href="/contact">Request a Brief</a></li>
          </ul>
        </div>

        <!-- Col 4: Company -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Company</h4>
          <ul class="site-footer__links">
            <li><a href="/about">About Crestmore</a></li>
            <li><a href="/team">Our Analysts</a></li>
            <li><a href="/methodology">Methodology</a></li>
            <li><a href="/coverage">Coverage Map</a></li>
            <li><a href="/press">Press &amp; Media</a></li>
            <li><a href="/about#careers">Careers</a></li>
            <li><a href="/about#esg">ESG Commitment</a></li>
          </ul>
        </div>

        <!-- Col 5: Contact -->
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">Contact</h4>
          <address class="site-footer__address">
            <p>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              245 Park Avenue, Suite 3900<br />
              New York, NY 10167
            </p>
            <p>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 014 1.18 2 2 0 016 3.18v3a2 2 0 01-1.45 1.93l-.27.27a16 16 0 006.29 6.29l.27-.27A2 2 0 0122 16.92z"/></svg>
              +1 (212) 555-0190
            </p>
            <p>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              research@crestmoreresearch.com
            </p>
          </address>
          <a href="/contact" class="site-footer__contact-cta">Request a Research Brief →</a>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom bar: legal -->
  <div class="site-footer__bottom">
    <div class="container">
      <div class="site-footer__bottom-inner">
        <p class="site-footer__copy">
          © {currentYear} Crestmore Research LLC. All rights reserved.
        </p>
        <nav class="site-footer__legal-nav" aria-label="Legal navigation">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Use</a>
          <a href="/disclosures">Disclosures</a>
          <a href="/cookies">Cookie Policy</a>
        </nav>
      </div>
      <p class="site-footer__disclaimer">
        The research, analysis, and commentary published by Crestmore Research LLC ("Crestmore") are provided for informational purposes only and do not constitute investment advice, a solicitation, or an offer to buy or sell any security or financial instrument. Crestmore is an independent research firm and is not registered as an investment adviser with any regulatory authority. Past performance is not indicative of future results. All data and forecasts are believed to be accurate at the time of publication but may be subject to revision. Institutional clients and sophisticated investors should conduct their own due diligence before acting on any research published by Crestmore.
      </p>
    </div>
  </div>
</footer>
