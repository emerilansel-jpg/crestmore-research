---
// ArticleCard.astro — Research article card for grid layout
interface Props {
  title: string;
  slug: string;
  category: string;
  description: string;
  author: string;
  date: Date;
  featured_image?: string;
}

const { title, slug, category, description, author, date, featured_image } = Astro.props;

// Format date: "April 27, 2026"
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

// Extract first name + last name (before comma if "Name, Title" format)
const authorDisplay = author.split(',')[0].trim();

// Derive initials for placeholder
const initials = authorDisplay
  .split(' ')
  .map((n: string) => n[0])
  .slice(0, 2)
  .join('');
---

<article class="article-card">
  <!-- Featured image -->
  <div class="article-card__image-wrap">
    {featured_image ? (
      <img
        class="article-card__image"
        src={featured_image}
        alt={title}
        loading="lazy"
        width="800"
        height="450"
      />
    ) : (
      <div class="article-card__image-placeholder" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Card body -->
  <div class="article-card__body">
    <span class="article-card__category">{category}</span>

    <h2 class="article-card__title">
      <a href={`/research/${slug}`}>{title}</a>
    </h2>

    <p class="article-card__excerpt">{description}</p>

    <div class="article-card__meta">
      <span class="article-card__author">{authorDisplay}</span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
  </div>
</article>
