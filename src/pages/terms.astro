---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Use — Crestmore Research"
  description="Terms and conditions governing use of Crestmore Research publications, website, and research services."
  canonicalUrl="https://crestmoreresearch.com/terms"
>
  <section class="legal-page">
    <div class="container">
      <div class="legal-page__header">
        <p class="legal-page__label">Legal</p>
        <h1 class="legal-page__title">Terms of Use</h1>
        <p class="legal-page__meta">Last updated: 1 January 2025 &nbsp;·&nbsp; Effective date: 1 January 2025</p>
      </div>

      <div class="legal-page__body">

        <p class="legal-page__intro">
          These Terms of Use ("Terms") govern your access to and use of the Crestmore Research LLC ("Crestmore") website and all research content, publications, data, and services provided therein. By accessing our website or subscribing to our research services, you agree to be bound by these Terms.
