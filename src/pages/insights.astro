---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('research');
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const commentaries = [
  { cat: 'Commodities', title: "Copper's Structural Deficit: Why the Bull Case Has Further to Run", date: 'April 2026', href: '/insights', readTime: '8 min read' },
  { cat: 'Emerging Markets', title: "India's Infrastructure Decade: Mapping the Capital Flow Opportunity", date: 'March 2026', href: '/insights', readTime: '6 min read' },
  { cat: 'Macro', title: 'Late-Cycle Dollar Dynamics and Their Implications for Hard Asset Pricing', date: 'March 2026', href: '/insights', readTime: '7 min read' },
  { cat: 'Country Risk', title: 'DRC Mining Sector: Regulatory Reset and the Road to Stabilisation', date: 'February 2026', href: '/insights', readTime: '10 min read' },
  { cat: 'Energy Transition', title: 'Critical Minerals Supply Chains: Four Scenarios for 2030', date: 'February 2026', href: '/insights', readTime: '12 min read' },
  { cat: 'Agriculture', title: 'Black Sea Grains: Navigating the Post-Conflict Trade Architecture', date: 'January 2026', href: '/insights', readTime: '9 min read' },
  { cat: 'Capital Flows', title: 'Sovereign Wealth Fund Reallocation: Where the Smart Money Is Moving', date: 'January 2026', href: '/insights', readTime: '7 min read' },
  { cat: 'Commodities', title: 'Gold\'s New Buyers: Central Bank Demand and the Dedollarisation Narrative', date: 'December 2025', href: '/insights', readTime: '8 min read' },
];

const cats = ['All', 'Commodities', 'Emerging Markets', 'Macro', 'Country Risk', 'Energy Transition', 'Agriculture', 'Capital Flows'];
---

<BaseLayout
  title="Insights — Crestmore Research"
  description="Market commentary, sector analysis, and research briefings from the Crestmore Research analyst team."
  pageType="default"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content">
        <p class="section__eyebrow section__eyebrow--gold">Analysis &amp; Commentary</p>
        <h1 class="page-hero__title">Insights</h1>
        <p class="page-hero__sub">Short-form analysis, market commentary, and sector briefings from our analyst team — free to access, published continuously.</p>
      </div>
    </div>
  </section>

  <!-- Filter bar -->
  <div class="insights-filter-bar">
    <div class="container">
      <div class="insights-filter">
        {cats.map(cat => (
          <button class={`insights-filter__btn${cat === 'All' ? ' insights-filter__btn--active' : ''}`} data-cat={cat}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- Commentary list -->
  <section class="section">
    <div class="container">
      <div class="section__header section__header--flex">
        <div>
          <p class="section__eyebrow">Market Commentary</p>
          <h2 class="section__title">Latest Insights</h2>
        </div>
      </div>
      <div class="insights-full-list">
        {commentaries.map(item => (
          <a href={item.href} class="insight-full-item">
            <span class="insight-full-item__cat" data-category={item.cat}>{item.cat}</span>
            <div class="insight-full-item__body">
              <h3 class="insight-full-item__title">{item.title}</h3>
              <div class="insight-full-item__meta">
                <span>{item.date}</span>
                <span class="insight-full-item__sep">·</span>
                <span>{item.readTime}</span>
              </div>
            </div>
            <svg class="insight-full-item__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Full research reports -->
  {posts.length > 0 && (
    <section class="section section--bg-soft">
      <div class="container">
        <div class="section__header">
          <p class="section__eyebrow">Full Research Reports</p>
          <h2 class="section__title">Published Research</h2>
        </div>
        <div class="article-grid">
          {posts.map(post => (
            <ArticleCard
              title={post.data.title}
              slug={post.id}
              category={post.data.category}
              description={post.data.description}
              author={post.data.author}
              date={post.data.date}
              featured_image={post.data.featured_image}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Newsletter CTA -->
  <section class="section section--dark">
    <div class="container">
      <div class="newsletter-cta">
        <div class="newsletter-cta__text">
          <p class="section__eyebrow section__eyebrow--gold">Stay Informed</p>
          <h2 class="section__title section__title--light">Weekly Intelligence Briefing</h2>
          <p style="font-family: 'Inter', sans-serif; font-size: 16px; color: rgba(255,255,255,0.6); line-height: 1.75; max-width: 480px; margin-top: 12px;">
            Our weekly briefing distils the most important market intelligence, country risk developments, and commodity price drivers — in 5 minutes. Free for qualified institutional readers.
          </p>
        </div>
        <div class="newsletter-cta__form">
          <p style="font-family: 'Inter', sans-serif; font-size: 13px; color: rgba(255,255,255,0.45); margin-bottom: 16px;">
            Institutional email addresses only. No spam. Unsubscribe any time.
          </p>
          <a href="/contact" class="btn btn--gold btn--lg">Request Access</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.insights-filter-bar {
  background: var(--bg-soft);
  border-bottom: 1px solid var(--border);
  padding: 16px 0;
  position: sticky;
  top: 136px;
  z-index: 100;
}

.insights-filter {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.insights-filter__btn {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-muted);
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 6px 14px;
  cursor: pointer;
  transition: color var(--transition), background var(--transition), border-color var(--transition);
  letter-spacing: 0.02em;
}

.insights-filter__btn:hover,
.insights-filter__btn--active {
  color: var(--navy-dark);
  background: var(--navy-dark);
  border-color: var(--navy-dark);
  color: #ffffff;
}

.insights-full-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.insight-full-item {
  display: grid;
  grid-template-columns: 140px 1fr 40px;
  align-items: center;
  gap: 24px;
  padding: 24px 28px;
  border-bottom: 1px solid var(--border);
  text-decoration: none;
  transition: background var(--transition);
}

.insight-full-item:last-child { border-bottom: none; }

.insight-full-item:hover {
  background: var(--bg-soft);
}

.insight-full-item__cat {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
}

.insight-full-item__title {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  font-weight: 600;
  color: var(--navy-dark);
  line-height: 1.35;
  margin-bottom: 6px;
  transition: color var(--transition);
}

.insight-full-item:hover .insight-full-item__title { color: var(--accent); }

.insight-full-item__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--text-muted);
}

.insight-full-item__sep { opacity: 0.5; }

.insight-full-item__arrow {
  color: var(--text-muted);
  transition: color var(--transition), transform var(--transition);
  justify-self: end;
}

.insight-full-item:hover .insight-full-item__arrow {
  color: var(--accent);
  transform: translateX(3px);
}

.newsletter-cta {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 60px;
  align-items: center;
}

@media (max-width: 768px) {
  .insights-filter-bar { position: static; }
  .insight-full-item { grid-template-columns: 1fr auto; gap: 16px; padding: 18px 20px; }
  .insight-full-item__cat { display: none; }
  .newsletter-cta { grid-template-columns: 1fr; gap: 32px; }
}
</style>
