---
import BaseLayout from '../layouts/BaseLayout.astro';

const leadership = [
  {
    name: 'Dr. Sarah Whitmore',
    role: 'Head of Commodities Research',
    photo: '/images/team-sarah.png',
    credentials: 'PhD Economics, LSE · Former World Bank Senior Economist',
    bio: 'Dr. Whitmore leads Crestmore\'s commodities research franchise, overseeing coverage of base metals, precious metals, and energy transition minerals. She has 20 years of experience in commodity markets, including six years as a senior economist at the World Bank\'s Extractive Industries division, where she led the design of resource revenue management frameworks for 14 developing economies. Her research has been cited by the IMF, OECD, and the World Economic Forum.',
    coverage: ['Base Metals', 'Precious Metals', 'Energy Transition Minerals', 'Mining Project Finance'],
    linkedin: 'https://linkedin.com',
  },
  {
    name: 'Marcus Chen, CFA',
    role: 'Director, Emerging Markets Research',
    photo: '/images/team-chen.png',
    credentials: 'MBA Finance, Wharton · CFA Charterholder · Former Goldman Sachs',
    bio: 'Marcus leads Crestmore\'s emerging markets practice, with specialist expertise in Southeast Asian and MENA capital flows, sovereign debt dynamics, and cross-border trade finance. Prior to joining Crestmore, he spent eight years at Goldman Sachs Asset Management as a portfolio manager specialising in EM fixed income and commodity-linked assets. He is a regular contributor to the Financial Times and has testified before the US Senate Banking Committee on emerging market financial stability.',
    coverage: ['Southeast Asia', 'MENA', 'Capital Flows & FX', 'Sovereign Debt'],
    linkedin: 'https://linkedin.com',
  },
  {
    name: 'Elena Vasquez',
    role: 'Senior Analyst, Country Risk',
    photo: '/images/team-vasquez.png',
    credentials: 'MSc Political Economy, Sciences Po · Fluent in 5 languages',
    bio: 'Elena is Crestmore\'s lead country risk analyst, specialising in the Andean region, Central Africa, and Eastern Europe. A political economy specialist with deep field experience, she has conducted research visits in 34 countries and maintains extensive networks with government officials, NGOs, and civil society organisations across her coverage markets. Her work on the DRC\'s mining regulatory environment and Bolivia\'s lithium nationalisation programme has been widely referenced by institutional investors.',
    coverage: ['Sub-Saharan Africa', 'Latin America', 'Eastern Europe', 'Regulatory Risk'],
    linkedin: 'https://linkedin.com',
  },
];

const analysts = [
  { name: 'James Okafor', role: 'Senior Analyst, Energy Transition', coverage: 'Lithium, Cobalt, Nickel' },
  { name: 'Priya Sharma', role: 'Analyst, Agricultural Commodities', coverage: 'Fertilisers, Soft Commodities, Agri-Input Chains' },
  { name: 'Tobias Richter', role: 'Quantitative Analyst', coverage: 'Price Modelling, Data Infrastructure, Supply-Demand Frameworks' },
  { name: 'Amara Diallo', role: 'Analyst, Sub-Saharan Africa', coverage: 'West Africa, East Africa, Francophone Markets' },
  { name: 'Yuki Tanaka', role: 'Analyst, Asia-Pacific', coverage: 'Japan, Korea, Southeast Asia Supply Chains' },
  { name: 'Natalia Kowalczyk', role: 'Analyst, Central & Eastern Europe', coverage: 'Poland, Czech Republic, Ukraine, Wider CEE' },
];
---

<BaseLayout
  title="Our Team — Crestmore Research"
  description="Meet the Crestmore Research analyst team — senior economists, sector specialists, and country risk experts with decades of combined institutional experience."
  pageType="default"
>

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content">
        <p class="section__eyebrow section__eyebrow--gold">The People Behind the Research</p>
        <h1 class="page-hero__title">Our Analysts</h1>
        <p class="page-hero__sub">Senior economists, former government officials, quantitative specialists, and field researchers — united by a commitment to independent, evidence-based analysis.</p>
      </div>
    </div>
  </section>

  <!-- Leadership team -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <p class="section__eyebrow">Senior Leadership</p>
        <h2 class="section__title">Research Leadership Team</h2>
      </div>
      <div class="leadership-list">
        {leadership.map(person => (
          <div class="leader-card">
            <div class="leader-card__photo-col">
              <div class="leader-card__photo-wrap">
                <img
                  src={person.photo}
                  alt={person.name}
                  loading="lazy"
                  class="leader-card__photo"
                />
              </div>
              <a href={person.linkedin} target="_blank" rel="noopener" class="leader-card__linkedin" aria-label={`${person.name} on LinkedIn`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn Profile
              </a>
            </div>
            <div class="leader-card__body">
              <h2 class="leader-card__name">{person.name}</h2>
              <p class="leader-card__role">{person.role}</p>
              <p class="leader-card__creds">{person.credentials}</p>
              <p class="leader-card__bio">{person.bio}</p>
              <div class="leader-card__coverage">
                <span class="leader-card__coverage-label">Coverage areas:</span>
                {person.coverage.map(c => <span class="leader-card__coverage-tag">{c}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Analysts -->
  <section class="section section--bg-soft">
    <div class="container">
      <div class="section__header">
        <p class="section__eyebrow">The Full Team</p>
        <h2 class="section__title">Research Analysts</h2>
      </div>
      <div class="analysts-grid">
        {analysts.map(analyst => (
          <div class="analyst-card">
            <div class="analyst-card__avatar">
              {analyst.name.split(' ').map(n => n[0]).join('')}
            </div>
            <div class="analyst-card__body">
              <h3 class="analyst-card__name">{analyst.name}</h3>
              <p class="analyst-card__role">{analyst.role}</p>
              <p class="analyst-card__coverage">{analyst.coverage}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Culture / careers teaser -->
  <section class="section section--dark">
    <div class="container">
      <div class="team-culture">
        <div>
          <p class="section__eyebrow section__eyebrow--gold">Join Us</p>
          <h2 class="section__title section__title--light">We Are Always Hiring</h2>
          <p style="font-family: 'Inter', sans-serif; font-size: 17px; color: rgba(255,255,255,0.65); line-height: 1.75; max-width: 560px; margin-top: 16px;">
            Crestmore is a small, high-quality team. We hire exceptional analysts who combine deep sector knowledge with intellectual curiosity and a commitment to independent thinking.
          </p>
          <p style="font-family: 'Inter', sans-serif; font-size: 17px; color: rgba(255,255,255,0.65); line-height: 1.75; max-width: 560px; margin-top: 12px;">
            We are currently seeking senior analysts with deep expertise in energy transition minerals and Sub-Saharan African sovereign debt markets.
          </p>
          <div style="display: flex; gap: 16px; margin-top: 40px; flex-wrap: wrap;">
            <a href="/contact" class="btn btn--gold">Send Your CV</a>
            <a href="/about" class="btn btn--outline">About Crestmore</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.leadership-list {
  display: flex;
  flex-direction: column;
  gap: 56px;
}

.leader-card {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: 48px;
  padding-bottom: 56px;
  border-bottom: 1px solid var(--border);
}

.leader-card:last-child { border-bottom: none; padding-bottom: 0; }

.leader-card__photo-wrap {
  width: 100%;
  aspect-ratio: 3/4;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--navy-mid);
  box-shadow: var(--card-shadow);
  margin-bottom: 12px;
}

.leader-card__photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
  display: block;
  background: linear-gradient(135deg, var(--navy-mid), var(--navy-dark));
}

.leader-card__linkedin {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 600;
  color: var(--accent);
  transition: color var(--transition);
}
.leader-card__linkedin:hover { color: var(--navy-dark); }

.leader-card__name {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--navy-dark);
  margin-bottom: 6px;
}

.leader-card__role {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 8px;
}

.leader-card__creds {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: 20px;
}

.leader-card__bio {
  font-family: 'Inter', sans-serif;
  font-size: 15.5px;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 24px;
}

.leader-card__coverage {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}

.leader-card__coverage-label {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
}

.leader-card__coverage-tag {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--navy-dark);
  background: var(--bg-soft);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 4px 10px;
  font-weight: 500;
}

.analysts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.analyst-card {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 20px;
  transition: box-shadow var(--transition);
}

.analyst-card:hover { box-shadow: var(--card-shadow); }

.analyst-card__avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--navy-mid);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 15px;
  font-weight: 700;
  color: rgba(255,255,255,0.85);
  flex-shrink: 0;
  letter-spacing: 0.05em;
}

.analyst-card__name {
  font-family: 'Playfair Display', serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--navy-dark);
  margin-bottom: 3px;
}

.analyst-card__role {
  font-family: 'Inter', sans-serif;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--accent);
  margin-bottom: 6px;
}

.analyst-card__coverage {
  font-family: 'Inter', sans-serif;
  font-size: 12.5px;
  color: var(--text-muted);
  line-height: 1.5;
  margin: 0;
}

.team-culture { max-width: 640px; }

@media (max-width: 768px) {
  .leader-card { grid-template-columns: 1fr; gap: 24px; }
  .leader-card__photo-wrap { max-width: 200px; }
  .leader-card__name { font-size: 22px; }
  .analysts-grid { grid-template-columns: 1fr; }
}
</style>
